{
  "kind": "collectionType",
  "collectionName": "newsletter_subscribers",
  "info": {
    "singularName": "newsletter-subscriber",
    "pluralName": "newsletter-subscribers",
    "displayName": "Newsletter Subscriber",
    "description": "Manage newsletter recipients"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "fullName": {
      "type": "string"
    },
    "organization": {
      "type": "string"
    },
    "source": {
      "type": "enumeration",
      "enum": [
        "fundraising-tracker",
        "website"
      ],
      "default": "website"
    },
    "sourceStatus": {
      "type": "string"
    },
    "connectedThrough": {
      "type": "string"
    },
    "isSubscribed": {
      "type": "boolean",
      "default": true
    },
    "subscribedAt": {
      "type": "datetime"
    },
    "unsubscribedAt": {
      "type": "datetime"
    },
    "unsubscribeToken": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "sourceMeta": {
      "type": "json"
    }
  }
}
